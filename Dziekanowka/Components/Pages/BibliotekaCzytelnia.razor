@using Dziekanowka.Mechanizm
<div class="bibliotekaCzytelniaWidok widok rel">
    <div class="abs czytelniaDoIntro"><button disabled="@czytanie" class="wyroznionyGuzik" @onclick="async () => await NaZmianeEkranu.InvokeAsync(EkranGry.BibliotekaIntro)"><img src="img/miasto/biblioteka/confirmCzytelnia.png" /></button></div>
    <div class="abs czytelniaKsiazki">
        @foreach (var lektura in lektury)
        {
            var lokalnaLektura = lektura;
            <div class="ksiazka" @onclick='() => Czytaj(lokalnaLektura)'><img class="obrazekContain" src="img/miasto/biblioteka/lektury/@(lektura).png" /></div>
        }
    </div>
</div>

@if (czytanie)
{
    <div class="abs czytelnia" @onclick="() => czytanie = false">
        <div class="trescKsiazki" @onclick:stopPropagation="true">
            <div class="stronaKsiazki"><p>@AktualnaStrona()</p></div>
            <div class="nawigacjaKsiazki">
                <button @onclick="PoprzedniaStrona" disabled="@(nrStrony <= 1)">◀</button>
                <input type="number" min="1" max="@liczbaStron" value="@nrStrony" @onchange="IdzDoStrony" />
                <span>/ @liczbaStron</span>
                <button @onclick="NastepnaStrona" disabled="@(nrStrony >= liczbaStron)">▶</button>
            </div>
        </div>
        <div class="zamknijKsiazke" @onclick="() => czytanie = false">✕</div>
    </div>
}

@code {
    [Parameter] public Gracz Gracz { get; set; } = null!;
    [Parameter] public EventCallback<EkranGry> NaZmianeEkranu { get; set; }
    private bool czytanie = false;
    private List<string> lektury = ["MalySwiatekDonCamilla", "RokDonCamilla", "TowarzyszDonCamillo", "DonCamilloIJegoTrzodka", "BladyWymoczek", "Ludziska", "DziesiatySpiskowiec",
    "GringoWsrodDzikichPlemion",
    "QuoVadis", "PanTadeusz", "WPustyniIWPuszczy", "OgniemIMieczem", "Potop", "PanWolodyjowski", "MalyKsiaze",
    "Narnia1LewCzarownicaIStaraSzafa", "Narnia2KsiazeKaspian", "Narnia3PodrozWedrowcaDoSwitu", "Narnia4SrebrneKrzeslo", "Narnia5KonIJegoChlopiec", "Narnia6SiostrzeniecCzarodzieja", "Narnia7OstatniaBitwa",
    "Hobbit", "DruzynaPierscienia1", "DruzynaPierscienia2", "DwieWieze1", "DwieWieze2", "PowrotKrola1", "PowrotKrola2",
    "Ania1ZZielonegoWzgorza", "Ania2AniaZAvonlea", "Ania3AniaNaUniwersytecie", "Ania4AniaZSzumiacychTopoli", "Ania5WymarzonyDomAni", "Ania6AniaZeZlotegoBrzegu", "Ania7DolinaTeczy", "Ania8RillaZeZlotegoBrzegu", "Ania9AniaZWyspyKsieciaEdwarda"];
    private int nrStrony = 1;
    private int liczbaStron = 0;
    private List<string> strony = [];
    private List<string> PodzielNaStrony(string tekst, int znakiNaStrone)
    {
        var strony = new List<string>();
        int i = 0;
        while (i < tekst.Length)
        {
            int koniec = Math.Min(i + znakiNaStrone, tekst.Length);
            if (koniec < tekst.Length)
            {
                int ostatniaSpacja = tekst.LastIndexOf(' ', koniec, koniec - i);
                if (ostatniaSpacja > i) koniec = ostatniaSpacja + 1;
            }
            strony.Add(tekst[i..koniec].Trim());
            i = koniec;
        }
        return strony;
    }
    private void Czytaj(string ksiazka)
    {
        var baseDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "wwwroot", "img", "miasto", "biblioteka", "lektury");
        var tekst = File.ReadAllText(Path.Combine(baseDir, $"{ksiazka}.txt"), System.Text.Encoding.UTF8);
        int znakiNaStrone = ksiazka == "PanTadeusz" ? 1000 : 3000;
        strony = PodzielNaStrony(tekst, znakiNaStrone);
        liczbaStron = strony.Count;
        nrStrony = 1;
        czytanie = true;
    }
    private string AktualnaStrona() => strony.Count > 0 ? strony[nrStrony - 1] : "";
    private void NastepnaStrona()
    {
        if (nrStrony < liczbaStron) nrStrony++;
    }
    private void PoprzedniaStrona()
    {
        if (nrStrony > 1) nrStrony--;
    }
    private void IdzDoStrony(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int nr))
        {
            if (nr >= 1 && nr <= liczbaStron)
                nrStrony = nr;
        }
    }
}