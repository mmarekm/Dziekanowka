@using Dziekanowka.Mechanizm
@using Dziekanowka.Gracza
@inject LadowanieGracza ladowanieGracza
@implements IDisposable
<div class="stacja@(stacja)Widok widok rel @(wyswietlonyRozklad ? "blokadaKlikniec" : "")">
    <div class="abs wyjscieStacja@(stacja)"><button class="wyroznionyGuzik" @onclick="async () => await NaZmianeEkranu.InvokeAsync(Wyjscie)"><img src="img/miasto/stacje/confirmStacja@(stacja).png" /></button></div>
    <div class="abs ileBiletowL@(stacja)">@Gracz.Przedmiot("biletPociag").Ilosc</div>
    <div class="abs ileBiletow@(stacja)"><img class="obrazekContain" src="img/przedmioty/biletPociag.png" /></div>
    <div class="abs stacjaCzas stacjaCzas@(stacja)">@czas</div>
    <div class="abs zobaczRozkladStacji@(stacja)"><button class="wyroznionyGuzik" @onclick="() => wyswietlonyRozklad = true"><img src="img/miasto/stacje/zobaczRozkladStacja@(stacja).png" /></button></div>
    @if (stacja == "miasto3")
    {
        <div class="abs zaslonaPociagu1miasto3"><img src="img/miasto/stacje/latarnia1Miasto3.png" /></div>
        <div class="abs zaslonaPociagu2miasto3"><img src="img/miasto/stacje/latarnia2Miasto3.png" /></div>
        <div class="abs zaslonaPociagu3miasto3"><img src="img/miasto/stacje/daszekMiasto3.png" /></div>
        <div class="abs pociagKazdyAnimacja pociag1@(stacja)Animacja @klasaPociagu1" @onclick="() => WsiadzDoPociagu(1)">
            <img class="obrazekWypelnia" src="img/miasto/pociag.png" />
            <div class="abs celPociagu"><img class="obrazekContain" src="img/miasto/stacje/miastoLesneLabel.png" /></div>
        </div>
    }
    @if (stacja == "miastoLesne")
    {
        <div class="abs zaslonaPociagu1miastoLesne"><img src="img/miasto/stacje/latarniaMiastoLesne.png" /></div>
        <div class="abs zaslonaPociagu2miastoLesne"><img src="img/miasto/stacje/daszekMiastoLesne.png" /></div>
        <div class="abs pociagKazdyAnimacja pociag2@(stacja)Animacja @klasaPociagu2" @onclick="() => WsiadzDoPociagu(2)">
            <img class="obrazekWypelnia" src="img/miasto/pociag.png" />
            <div class="abs celPociagu"><img class="obrazekContain" src="img/miasto/stacje/miasto3Label.png" /></div>
        </div>
    }
    <div class="abs kupBiletStacja@(stacja) @(Gracz.Monety >= cenaBiletu ? "klikalneDivZielone" : "nieMoznaKliknac")" @onclick="KupBilet"><img src="img/miasto/stacje/kupBiletStacja@(stacja).png" /></div>
</div>
@if (wyswietlonyRozklad)
{
    <div class="abs overlayRoklady">
        <div class="abs wypisaneRozklady">
            @if (stacja == "miasto3")
            {
                <div class="rozkladPociagu1">
                    <div class="nazwaPociagu1"><img src="img/miasto/stacje/miastoLesneLabel.png" /></div>
                    @for (int i = 0; i < odjazdyMiasto3DoMiastaLesnego.Length; i++)
                    {
                        <div>@odjazdyMiasto3DoMiastaLesnego[i]</div>
                    }
                </div>
            }
            @if (stacja == "miastoLesne")
            {
                <div class="rozkladPociagu1">
                    <div class="nazwaPociagu1"><img src="img/miasto/stacje/miasto3Label.png" /></div>
                    @for (int i = 0; i < odjazdyMiastoLesneDoMiasta3.Length; i++)
                    {
                        <div>@odjazdyMiastoLesneDoMiasta3[i]</div>
                    }
                </div>
            }
        </div>
        <div class="abs zamknijRozklady"><button class="wyroznionyGuzik" @onclick="() => wyswietlonyRozklad = false"><img class="obrazekContain" src="img/dom/potwierdzenie.png" /></button></div>
    </div>
}
@code {
    [Parameter] public Gracz Gracz { get; set; } = null!;
    [Parameter] public EventCallback<EkranGry> NaZmianeEkranu { get; set; }
    private CancellationTokenSource? _ctsZegar;
    private string stacja => Gracz.Statystyki.Stacja;
    private int czas = 0;
    private bool wyswietlonyRozklad = false;
    private int[] odjazdyMiasto3DoMiastaLesnego = [10, 25, 35, 60, 90];
    private int[] odjazdyMiastoLesneDoMiasta3 = [8, 20, 50, 85];
    private string klasaPociagu1 = "";
    private string klasaPociagu2 = "";
    private bool moznaWsiascPociag = false;
    protected override void OnParametersSet()
    {
        AktualizujPociagi();
        if (_ctsZegar == null)
        {
            _ctsZegar = new CancellationTokenSource();
            _ = Zegar(_ctsZegar.Token);
        }
    }
    private async Task Zegar(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(800, token);
                czas = (czas + 1) % 100;
                AktualizujPociagi();
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }
    private void AktualizujPociagi()
    {
        if (stacja == "miasto3")
        {
            (klasaPociagu1, moznaWsiascPociag) = StanPociagu("pociag1", odjazdyMiasto3DoMiastaLesnego);
        }
        if (stacja == "miastoLesne")
        {
            (klasaPociagu2, moznaWsiascPociag) = StanPociagu("pociag2", odjazdyMiastoLesneDoMiasta3);
        }
    }
    private (string, bool) StanPociagu(string nazwa, int[] rozklad)
    {
        foreach (var odjazd in rozklad)
        {
            var offset = (czas - odjazd + 100) % 100;
            if (offset is 97 or 98 or 99)
                return ("kazdyPociagJedzie", false);
            if (offset is 0 or 1 or 2)
                return ("kazdyPociagStoi", true);
            if (offset is 3 or 4 or 5)
                return ($"kazdyPociagOdjedzie {nazwa}{stacja}Odjedzie", false);
        }
        return ($"kazdyPociagUkryty {nazwa}{stacja}Ukryty", false);
    }
    private EkranGry Wyjscie => stacja switch { "miasto3" => EkranGry.Miasto3, "miastoLesne" => EkranGry.MiastoLesne, _ => throw new ArgumentOutOfRangeException() };
    private int cenaBiletu => stacja == "miasto3" ? 7 : 10;
    private async Task KupBilet()
    {
        if (Gracz.Monety < cenaBiletu) return;
        Gracz.Monety -= cenaBiletu;
        Gracz.Przedmiot("biletPociag").Ilosc++;
        await ladowanieGracza.ZapiszAktualnegoGracza();
    }
    public async Task WsiadzDoPociagu(int nrPociagu)
    {
        if (Gracz.Przedmiot("biletPociag").Ilosc < 1 || !moznaWsiascPociag) return;
        Gracz.Przedmiot("biletPociag").Ilosc--;
        czas = 0;
        Gracz.Statystyki.Stacja = nrPociagu == 1 ? "miastoLesne" : "miasto3";
        await ladowanieGracza.ZapiszAktualnegoGracza();
    }
    public void Dispose()
    {
        _ctsZegar?.Cancel();
    }
}