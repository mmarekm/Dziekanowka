@using Dziekanowka.Rozgrywki
@using Dziekanowka.Mechanizm
@inject LadowanieGracza LadowanieGracza
<div class="abs partiaSzachy @KlasaCss">
    <div class="obrazSzachownicy">
        @foreach (var pole in Partia.Plansza)
        {
            var kolumna = Odwrocona ? 9 - pole.X : pole.X;
            var rzad = Odwrocona ? pole.Y : 9 - pole.Y;
            if (pole.Bierka != "")
            {
                <img class="@KlasaBierki(pole)" src="img/dom/salon/szachy/@(pole.Bierka).png" style="@($"grid-column: {kolumna}; grid-row: {rzad};")" @onclick="async () => await PoleKlik(pole)" />
            }
            else
            {
                <div class="@KlasaPustegoPola(pole)" style="@($"grid-column: {kolumna}; grid-row: {rzad};")" @onclick="async () => await PoleKlik(pole)"></div>
            }
        }
    </div>
    <div class="rel menuSzachisty">
        <div class="abs klikSzachy punktyGraczaSzachy punktyRywalaSzachy">@punktyPrzeciwnika</div>
        <div class="abs klikSzachy poddajSieSzachy" @onclick="() => chybaPrzegram = true"><img class="obrazekSieMiesci" src="img/dom/salon/porazka.png" /></div>
        <div class="abs klikSzachy proponujRemisSzachy" @onclick="ProponujRemis"><img class="obrazekSieMiesci" src="img/dom/salon/remis.png" /></div>
        <div class="abs klikSzachy punktyGraczaSzachy punktyMojeSzachy">@punktyGracza</div>
    </div>
    @if (Partia.TrwaPropozyjaRemisu != "")
    {
        <div class="abs overlaySzachy overlayRemis">
            @if (Partia.TrwaPropozyjaRemisu == NazwaGracza)
            {
                <div class="abs przyciskSzachy decyzjaSzachyTak"><button class="wyroznionyGuzik" @onclick="PrzyjmijRemis"><img class="obrazekWypelnia" src="img/dom/potwierdzenie.png" /></button></div>
                <div class="abs przyciskSzachy decyzjaSzachyNie"><button class="wyroznionyGuzik" @onclick="OdrzucRemis"><img class="obrazekWypelnia" src="img/dom/rezygnacja.png" /></button></div>
            }
        </div>
    }
    @if (chybaPrzegram)
    {
        <div class="abs overlaySzachy overlayPorazka">
            <div class="abs przyciskSzachy decyzjaSzachyTak"><button class="wyroznionyGuzik" @onclick="PoddajSie"><img class="obrazekWypelnia" src="img/dom/potwierdzenie.png" /></button></div>
            <div class="abs przyciskSzachy decyzjaSzachyNie"><button class="wyroznionyGuzik" @onclick="() => chybaPrzegram = false"><img class="obrazekWypelnia" src="img/dom/rezygnacja.png" /></button></div>
        </div>
    }
    @if (oczekujePromocji)
    {
        <div class="abs overlaySzachy overlayPromocja">
            <div class="abs przyciskSzachy promocjaHetman" @onclick='() => Promuj("hetman")'><img class="obrazekWypelnia" src="img/dom/salon/szachy/hetman@(kolorPromocji).png" /></div>
            <div class="abs przyciskSzachy promocjaWieza" @onclick='() => Promuj("wieza")'><img class="obrazekWypelnia" src="img/dom/salon/szachy/wieza@(kolorPromocji).png" /></div>
            <div class="abs przyciskSzachy promocjaGoniec" @onclick='() => Promuj("goniec")'><img class="obrazekWypelnia" src="img/dom/salon/szachy/goniec@(kolorPromocji).png" /></div>
            <div class="abs przyciskSzachy promocjaSkoczek" @onclick='() => Promuj("skoczek")'><img class="obrazekWypelnia" src="img/dom/salon/szachy/skoczek@(kolorPromocji).png" /></div>
        </div>
    }
</div>

@code {
    [Parameter] public PartiaSzachow Partia { get; set; } = null!;
    [Parameter] public string KlasaCss { get; set; } = "";
    [Parameter] public bool Odwrocona { get; set; } = false;
    [Parameter] public SerwisSzachowy Serwis { get; set; } = null!;
    [Parameter] public Gracz Gracz { get; set; } = null!;
    private Gracz? rywal;
    protected override async Task OnInitializedAsync()
    {
        rywal = await LadowanieGracza.PobierzGracza(NazwaPrzeciwnika);
    }
    private string NazwaGracza => Odwrocona ? Partia.NazwaCzarnego : Partia.NazwaBialego;
    private string NazwaPrzeciwnika => Odwrocona ? Partia.NazwaBialego : Partia.NazwaCzarnego;
    private PoleSzachownicy? wybranaBierka;
    private List<PoleSzachownicy> mozliweRuchy = [];
    private bool chybaPrzegram = false;
    private double punktyGracza => Gracz.Statystyki.Mecze.Szachy.TryGetValue($"{NazwaPrzeciwnika}{(Odwrocona ? "Czarny" : "Bialy")}", out var p) ? p : 0;
    private double punktyPrzeciwnika => rywal?.Statystyki.Mecze.Szachy.TryGetValue($"{NazwaGracza}{(Odwrocona ? "Bialy" : "Czarny")}", out var p) == true ? p : 0;
    private bool oczekujePromocji = false;
    private PoleSzachownicy? polePromocji = null;
    private string? kolorPromocji = null;
    private int? ostatniStartX, ostatniStartY;
    private string KlasaBierki(PoleSzachownicy pole)
    {
        var klasy = new List<string> { "bierka" };
        if (wybranaBierka?.X == pole.X && wybranaBierka?.Y == pole.Y)
            klasy.Add("zaznaczonaBierka");
        if (Partia.OstatniRuchX == pole.X && Partia.OstatniRuchY == pole.Y)
            klasy.Add("poprzedniRuchTutaj");
        if (mozliweRuchy.Any(p => p.X == pole.X && p.Y == pole.Y))
            klasy.Add("mozliwyRuch");
        return string.Join(" ", klasy);
    }
    private string KlasaPustegoPola(PoleSzachownicy pole)
    {
        var klasy = new List<string> { "poleSzachownicy" };
        if (mozliweRuchy.Any(p => p.X == pole.X && p.Y == pole.Y))
            klasy.Add("mozliwyRuch");
        return string.Join(" ", klasy);
    }
    private async Task PoleKlik(PoleSzachownicy pole)
    {
        if (oczekujePromocji) return;
        if (Partia.RuchBialych == Odwrocona) return;
        if (wybranaBierka == null)
        {
            if (pole.Bierka != "" && pole.Bierka.EndsWith("Bialy") == Partia.RuchBialych)
            {
                wybranaBierka = pole;
                mozliweRuchy = MechanizmSzachow.MozliweRuchy(pole, Partia.Plansza, Partia);
            }
            return;
        }
        if (wybranaBierka.X == pole.X && wybranaBierka.Y == pole.Y)
        {
            wybranaBierka = null;
            mozliweRuchy = [];
            return;
        }
        if (pole.Bierka != "" && wybranaBierka.Bierka.EndsWith("Bialy") == pole.Bierka.EndsWith("Bialy"))
        {
            wybranaBierka = pole;
            mozliweRuchy = MechanizmSzachow.MozliweRuchy(pole, Partia.Plansza, Partia);
            return;
        }
        if (!mozliweRuchy.Any(p => p.X == pole.X && p.Y == pole.Y)) return;
        if (wybranaBierka.Bierka.StartsWith("pion") &&
            pole.X != wybranaBierka.X && pole.Bierka == "")
        {
            var zbityPion = Pole(pole.X, wybranaBierka.Y);
            if (zbityPion != null) zbityPion.Bierka = "";
        }
        pole.Bierka = wybranaBierka.Bierka;
        string bierkaNazwa = pole.Bierka;
        bool czyKrol = bierkaNazwa.StartsWith("krol");
        bool czyWieza = bierkaNazwa.StartsWith("wieza");
        int staryX = wybranaBierka.X;
        int staryY = wybranaBierka.Y;
        bool biala = bierkaNazwa.EndsWith("Bialy");
        if (czyKrol && Math.Abs(pole.X - staryX) == 2)
        {
            int y = pole.Y;
            int nowaXWiezy, staraXWiezy;
            if (pole.X == 7)
            {
                staraXWiezy = 8;
                nowaXWiezy = 6;
            }
            else if (pole.X == 3)
            {
                staraXWiezy = 1;
                nowaXWiezy = 4;
            }
            else return;
            var wieza = Pole(staraXWiezy, y);
            var nowePoleWiezy = Pole(nowaXWiezy, y);
            if (wieza != null && nowePoleWiezy != null && wieza.Bierka.StartsWith("wieza"))
            {
                nowePoleWiezy.Bierka = wieza.Bierka;
                wieza.Bierka = "";
                bool bialaWiezy = nowePoleWiezy.Bierka.EndsWith("Bialy");
                if (bialaWiezy && staraXWiezy == 1)
                    Partia.BialaWiezaKrolowaRuszala = true;
                else if (bialaWiezy && staraXWiezy == 8)
                    Partia.BialaWiezaKrolRuszala = true;
                else if (!bialaWiezy && staraXWiezy == 1)
                    Partia.CzarnaWiezaKrolowaRuszala = true;
                else if (!bialaWiezy && staraXWiezy == 8)
                    Partia.CzarnaWiezaKrolRuszala = true;
            }
        }
        wybranaBierka.Bierka = "";
        if (czyKrol)
        {
            if (biala) Partia.BialyKrolRuszal = true;
            else Partia.CzarnyKrolRuszal = true;
        }
        if (czyWieza)
        {
            if (biala && staryX == 1 && staryY == 1) Partia.BialaWiezaKrolowaRuszala = true;
            else if (biala && staryX == 8 && staryY == 1) Partia.BialaWiezaKrolRuszala = true;
            else if (!biala && staryX == 1 && staryY == 8) Partia.CzarnaWiezaKrolowaRuszala = true;
            else if (!biala && staryX == 8 && staryY == 8) Partia.CzarnaWiezaKrolRuszala = true;
        }
        ostatniStartX = staryX;
        ostatniStartY = staryY;
        if (bierkaNazwa.StartsWith("pion") && (pole.Y == 8 || pole.Y == 1))
        {
            oczekujePromocji = true;
            polePromocji = pole;
            kolorPromocji = biala ? "Bialy" : "Czarny";
            wybranaBierka = null;
            mozliweRuchy = [];
            StateHasChanged();
            return;
        }
        Partia.OstatniRuchX = pole.X;
        Partia.OstatniRuchY = pole.Y;
        Partia.OstatniStartX = staryX;
        Partia.OstatniStartY = staryY;
        Partia.OstatniaBierka = bierkaNazwa;
        Partia.RuchBialych = !Partia.RuchBialych;
        ostatniStartX = null;
        ostatniStartY = null;
        wybranaBierka = null;
        mozliweRuchy = [];
        await Serwis.ZapiszPartie(Partia);
    }
    private async Task DodajPunkty(double dlaGracza, double dlaRywala)
    {
        var kluczGracza = $"{NazwaPrzeciwnika}{(Odwrocona ? "Czarny" : "Bialy")}";
        var kluczRywala = $"{NazwaGracza}{(Odwrocona ? "Bialy" : "Czarny")}";
        Gracz.Statystyki.Mecze.Szachy.TryGetValue(kluczGracza, out var obecneGracza);
        Gracz.Statystyki.Mecze.Szachy[kluczGracza] = obecneGracza + dlaGracza;
        await LadowanieGracza.ZapiszAktualnegoGracza();
        rywal = await LadowanieGracza.PobierzGracza(NazwaPrzeciwnika);
        rywal.Statystyki.Mecze.Szachy.TryGetValue(kluczRywala, out var obecneRywala);
        rywal.Statystyki.Mecze.Szachy[kluczRywala] = obecneRywala + dlaRywala;
        await LadowanieGracza.ZapiszGracza(rywal);
        rywal = await LadowanieGracza.PobierzGracza(NazwaPrzeciwnika);
    }
    private async Task ProponujRemis()
    {
        Partia.TrwaPropozyjaRemisu = NazwaPrzeciwnika;
        await Serwis.ZapiszPartie(Partia);
    }
    private async Task PrzyjmijRemis()
    {
        await DodajPunkty(0.5, 0.5);
        await NowaPartia();
    }
    private async Task OdrzucRemis()
    {
        Partia.TrwaPropozyjaRemisu = "";
        await Serwis.ZapiszPartie(Partia);
    }
    private async Task PoddajSie()
    {
        chybaPrzegram = false;
        await DodajPunkty(0, 1);
        await NowaPartia();
    }
    private async Task NowaPartia()
    {
        Partia.Plansza = PartiaSzachow.StartowePlansza();
        Partia.RuchBialych = true;
        Partia.OstatniRuchX = 0;
        Partia.OstatniRuchY = 0;
        Partia.OstatniStartX = 0;
        Partia.OstatniStartY = 0;
        Partia.OstatniaBierka = "";
        Partia.TrwaPropozyjaRemisu = "";
        Partia.BialyKrolRuszal = false;
        Partia.BialaWiezaKrolowaRuszala = false;
        Partia.BialaWiezaKrolRuszala = false;
        Partia.CzarnyKrolRuszal = false;
        Partia.CzarnaWiezaKrolowaRuszala = false;
        Partia.CzarnaWiezaKrolRuszala = false;
        await Serwis.ZapiszPartie(Partia);
    }
    private PoleSzachownicy? Pole(int x, int y) => Partia.Plansza.FirstOrDefault(p => p.X == x && p.Y == y);
    private async Task Promuj(string figura)
    {
        if (polePromocji == null || kolorPromocji == null) return;
        polePromocji.Bierka = figura + kolorPromocji;
        Partia.OstatniRuchX = polePromocji.X;
        Partia.OstatniRuchY = polePromocji.Y;
        Partia.OstatniStartX = ostatniStartX ?? 0;
        Partia.OstatniStartY = ostatniStartY ?? 0;
        Partia.OstatniaBierka = polePromocji.Bierka;
        Partia.RuchBialych = !Partia.RuchBialych;
        oczekujePromocji = false;
        polePromocji = null;
        kolorPromocji = null;
        ostatniStartX = null;
        ostatniStartY = null;
        await Serwis.ZapiszPartie(Partia);
    }
}