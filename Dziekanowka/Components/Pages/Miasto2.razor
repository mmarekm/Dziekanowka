@using Dziekanowka.Mechanizm
@using Dziekanowka.Gracza
@inject LadowanieGracza ladowanieGracza
@implements IDisposable

<div class="miasto2Widok widok rel">
    <div class="abs lBiletowMiasto1">@Gracz.Przedmiot("biletAutobus").Ilosc</div>
    <div class="abs autobusAnimacjaM21 @klasaAutobusu1" @onclick="WsiadzDoAutobusu1"><img class="obrazekWypelnia" src="img/miasto/autobus.png" /></div>
    <div class="abs autobusAnimacjaM22 @klasaAutobusu2" @onclick="WsiadzDoAutobusu2"><img class="obrazekWypelnia" src="img/miasto/autobus.png" /></div>
    <div class="abs miasto2doSklepDzikich"><button class="wyroznionyGuzik" @onclick="async () => await NaZmianeEkranu.InvokeAsync(EkranGry.SklepDzikie)"><img src="img/miasto/miastoDoSklepDzikich.png" /></button></div>
    <div class="abs miasto2doSklepiczek"><button class="wyroznionyGuzik" @onclick="async () => await NaZmianeEkranu.InvokeAsync(EkranGry.Sklepiczek)"><img src="img/miasto/miastoDoSklepiczku.png" /></button></div>
    <div class="abs miasto2DoKiosk"><button class="wyroznionyGuzik" @onclick="DoKiosku"><img src="img/miasto/miasto2DoKiosk.png" /></button></div>
</div>

@code {
    [Parameter] public Gracz Gracz { get; set; } = null!;
    [Parameter] public EventCallback<EkranGry> NaZmianeEkranu { get; set; }
    private string klasaAutobusu1 = "autobusUkrytyM21";
    private string klasaAutobusu2 = "autobusUkrytyM22";
    private bool moznaWsiasc1 = false;
    private bool moznaWsiasc2 = false;
    private CancellationTokenSource? _cts;
    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = PetlaAutobusu1(_cts.Token);
        _ = PetlaAutobusu2(_cts.Token);
    }
    private async Task PetlaAutobusu1(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(5000, token);
                klasaAutobusu1 = "autobusStoiM21";
                moznaWsiasc1 = true;
                StateHasChanged();
                await Task.Delay(2000, token);
                moznaWsiasc1 = false;
                klasaAutobusu1 = "autobusUkrytyM21";
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }
    private async Task PetlaAutobusu2(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(7000, token);
                klasaAutobusu2 = "autobusStoiM22";
                moznaWsiasc2 = true;
                StateHasChanged();
                await Task.Delay(2000, token);
                moznaWsiasc2 = false;
                klasaAutobusu2 = "autobusUkrytyM22";
                StateHasChanged();
            }
        }
        catch (TaskCanceledException) { }
    }
    public async Task WsiadzDoAutobusu1()
    {
        if (Gracz.Przedmiot("biletAutobus").Ilosc < 1 || !moznaWsiasc1) return;
        Gracz.Przedmiot("biletAutobus").Ilosc--;
        await NaZmianeEkranu.InvokeAsync(EkranGry.AutobusJedzie21);
        await Task.Delay(8000);
        await NaZmianeEkranu.InvokeAsync(EkranGry.Miasto1);
    }
    public async Task WsiadzDoAutobusu2()
    {
        if (Gracz.Przedmiot("biletAutobus").Ilosc < 1 || !moznaWsiasc2) return;
        Gracz.Przedmiot("biletAutobus").Ilosc--;
        await NaZmianeEkranu.InvokeAsync(EkranGry.AutobusJedzie22);
        await Task.Delay(5000);
        await NaZmianeEkranu.InvokeAsync(EkranGry.Miasto3);
    }
    public async Task DoKiosku()
    {
        Gracz.Statystyki.Kiosk = 2;
        await NaZmianeEkranu.InvokeAsync(EkranGry.Kiosk);
    }
    public void Dispose()
    {
        _cts?.Cancel();
    }
}